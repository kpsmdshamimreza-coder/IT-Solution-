rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Allow read/write access to products
    match /products/{productId} {
      allow read, write: if true;
    }

    // Allow read/write access to sales
    match /sales/{saleId} {
      allow read, write: if true;
    }
  }
}
